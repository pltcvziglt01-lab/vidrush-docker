# Vidrush Video Botu — ornek env. Kopyala: cp .env.example .env, sonra doldur.
# Sifreleme anahtari: rastgele uzun bir dize (bir kez belirle, degistirme).
N8N_ENCRYPTION_KEY=degistir_rastgele_uzun_bir_dize
SEED_EMAIL=eposta@ornek.com
SEED_PASSWORD=guclu_bir_parola

# BotFather'dan alinan token
TELEGRAM_TOKEN=1234567890:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# platform.openai.com/api-keys (kartli hesap sart)
OPENAI_KEY=sk-proj-...
# pexels.com/api (ucretsiz, opsiyonel; yoksa stok sahneler AI'a duser)
PEXELS_KEY=PEXELS_KEY_GIRILECEK

# n8n'in Telegram'a bildirdigi webhook (cozulur bir HTTPS olmali; kopru zaten devralir)
WEBHOOK_URL=https://ornek-alan-adin.com/n8n
